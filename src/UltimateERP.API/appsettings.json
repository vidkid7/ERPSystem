{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=UltimateERP;Username=erp_user;Password=erp_password"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ElasticSearch": {
    "Uri": ""
  },
  "Cors": {
    "Origins": [ "http://localhost:3000", "http://localhost:5173" ]
  },
  "Jwt": {
    "Authority": "http://localhost:8080/realms/ultimate-erp",
    "Audience": "ultimate-erp-api",
    "RequireHttpsMetadata": false
  },
  "AllowedHosts": "*"
}
